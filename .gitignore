# Fixture-server build artifacts (per-server `go build` output).
fixtures/servers/*/*.exe
fixtures/servers/*/fx-*
!fixtures/servers/*/fx-*.go
!fixtures/servers/*/fx-*.md

# Verify-harness binary.
fixtures/verify/verify
fixtures/verify/verify.exe

# Stray probe / debug logs.
fixtures/servers/*/*.log
fixtures/servers/*/*.tmp

# Vercel link state (per-machine).
.vercel/

# Private dev companion (Quigleybits/mclip-dev) is nested here as its own
# git repo so the IDE sees one workspace. Never staged into public history.
/_dev/
